MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d8c91d01c7a20114ab571b96e0ae5f2c, type: 3}
  m_Name: NPC1_4
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  introDialogue:
  - NPCName: NPC1
    text: Sweetheart! I'd really like something as soft as a mimosa, to relax, to
      take it easy cause I have too many things on my plate right now!
  - NPCName: Barman
    text: Right away ma'am! I will materialise clouds in which you could completeley
      let go of today and watch tomorrow from above!
  drinkDialogue:
  - NPCName: NPC1
    text: Oh Dear!
  dropDialogue:
  - NPCName: NPC1
    text: That was delicious! Absolutely exquisite!
  - NPCName: Barman
    text: It pleases me most to hear that!
  exitDialogue:
  - NPCName: NPC1
    text: I will find out everything about this matrix! I will beat the hell out
      of it!
  - NPCName: Barman
    text: I think it would be wise to go home accompanied by a trusted person or
      in a cab. Have a good night!

MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d8c91d01c7a20114ab571b96e0ae5f2c, type: 3}
  m_Name: NPC1Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  introDialogue:
  - NPCName: NPC1
    text: 'Heya Darling! Could you hook me up with some delicious, sweet sweet love,
      by any chance? Like Sex on the Beach vibes.. '
  - NPCName: Barman
    text: 'So I gather that you have wonder and lust ma''am... I''ll fix up something
      right away '
  drinkDialogue:
  - NPCName: NPC1
    text: Oh, my Lord!
  dropDialogue:
  - NPCName: NPC1
    text: Well that was amazing indeed!
  - NPCName: Barman
    text: I am glad you enjoyed that!
  exitDialogue:
  - NPCName: NPC1
    text: I think, I think there's something chaining me into this loop... this script,
      this life! I need to get out!
  - NPCName: Barman
    text: A fresh breath of air is always recommended in cases like these. Do take
      care, ma'am! Have a great night!
